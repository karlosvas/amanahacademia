---
import Layout from "@/layouts/Layout.astro";
import { ApiService } from "@/services/helper";
import { log } from "@/services/logger";

const title = "Group Class Survey";
const description =
  "Complete our survey to understand your profile as a student and help us place you in the Spanish group that best suits your level and needs.";

const token = Astro.cookies.get("session")?.value ?? "";

if (!token) {
  log.error("No session token found in cookies for Panel Admin Page");
  return Astro.redirect("/");
}

const helper = new ApiService();
const user = await helper.getUser(token);
---

<Layout title={title} description={description}>
  <main class="survey-shell">
    <section class="survey-card">
      <header class="survey-header">
        <p class="eyebrow">Amanah Academia</p>
        <h1>{title}</h1>
        <p class="description">
          The purpose of this survey is to understand your profile as a student so that we can place you in the Spanish
          group that best suits your level and needs.
        </p>
        <button type="button" class="change-account my-5">{user.success ? user.data.email : "Anonymous"}</button>
      </header>

      <form class="survey-form" action="#" method="post">
        <label class="question-block" for="name">
          <span class="question-title">What is your name?</span>
          <input id="name" name="name" type="text" placeholder="Your full name" required />
        </label>

        <label class="question-block" for="age">
          <span class="question-title">How old are you?</span>
          <input id="age" name="age" type="number" min="1" max="100" placeholder="Your age" required />
        </label>

        <label class="question-block" for="native-language">
          <span class="question-title">What is your native language?</span>
          <input id="native-language" name="native-language" type="text" placeholder="Example: Arabic" required />
        </label>

        <div class="question-block" role="group" aria-labelledby="label-spanish-level">
          <span class="question-title" id="label-spanish-level">What is your current Spanish level?</span>

          <label class="option-row">
            <input type="radio" name="spanish-level" value="beginner" required />
            <span>I am a complete beginner</span>
          </label>

          <label class="option-row">
            <input type="radio" name="spanish-level" value="A1" />
            <span>A1. I know the alphabet, basic greetings and how to introduce myself</span>
          </label>

          <label class="option-row">
            <input type="radio" name="spanish-level" value="A2" />
            <span>
              A2. I have some basic knowledge of Spanish grammar. I can understand a native speaker talking about
              everyday topics if they speak slowly, and I can have very short and simple conversations
            </span>
          </label>

          <label class="option-row">
            <input type="radio" name="spanish-level" value="B1" />
            <span>
              B1. I have been studying Spanish for at least 4 months. I can understand simple conversations between
              native speakers and express myself with some confidence, although I still lack grammar and fluency.
            </span>
          </label>

          <label class="option-row">
            <input type="radio" name="spanish-level" value="B2" />
            <span>
              B2. I can use most verb tenses. I can express myself on topics beyond everyday situations. I can
              understand native speakers in both conversations and podcasts, whether they speak slowly or at a normal
              pace.
            </span>
          </label>

          <label class="option-row">
            <input type="radio" name="spanish-level" value="C1" />
            <span>
              C1. I have been studying Spanish for at least 2 years. I have a strong grasp of grammar and can understand
              native speakers without difficulty, even in group conversations or when they use slang or irony.
            </span>
          </label>

          <label class="option-row">
            <input type="radio" name="spanish-level" value="other" data-other-toggle="level" />
            <span>Other:</span>
          </label>
          <input
            class="other-input"
            id="spanish-level-other"
            name="spanish-level-other"
            type="text"
            placeholder="Write your level"
            disabled
          />
        </div>

        <div class="question-block" role="group" aria-labelledby="label-other-languages">
          <span class="question-title" id="label-other-languages"
            >Do you speak any other languages beside your native language?</span
          >

          <label class="option-row">
            <input type="checkbox" name="other-languages" value="English" />
            <span>English</span>
          </label>

          <label class="option-row">
            <input type="checkbox" name="other-languages" value="Italian" />
            <span>Italian</span>
          </label>

          <label class="option-row">
            <input type="checkbox" name="other-languages" value="French" />
            <span>French</span>
          </label>

          <label class="option-row">
            <input type="checkbox" name="other-languages" value="Portuguese" />
            <span>Portuguese</span>
          </label>

          <label class="option-row">
            <input type="checkbox" name="other-languages" value="German" />
            <span>German</span>
          </label>

          <label class="option-row">
            <input type="checkbox" name="other-languages" value="other" data-other-toggle="languages" />
            <span>Other:</span>
          </label>
          <input
            class="other-input"
            id="languages-other"
            name="languages-other"
            type="text"
            placeholder="Write another language"
            disabled
          />
        </div>

        <div class="question-block" role="group" aria-labelledby="label-focus">
          <span class="question-title" id="label-focus">What would you like to focus on the most during the class?</span
          >

          <label class="option-row">
            <input type="radio" name="focus" value="listening" required />
            <span>Listening skills</span>
          </label>

          <label class="option-row">
            <input type="radio" name="focus" value="grammar" />
            <span>Grammar</span>
          </label>

          <label class="option-row">
            <input type="radio" name="focus" value="speaking" />
            <span>Speaking skills / conversation practice</span>
          </label>

          <label class="option-row">
            <input type="radio" name="focus" value="other" data-other-toggle="focus" />
            <span>Other:</span>
          </label>
          <input
            class="other-input"
            id="focus-other"
            name="focus-other"
            type="text"
            placeholder="Tell us your focus"
            disabled
          />
        </div>

        <label class="question-block" for="extra-notes">
          <span class="question-title">Is there anything else you would like to add?</span>
          <textarea id="extra-notes" name="extra-notes" rows="5" placeholder="Any details you want us to know"
          ></textarea>
        </label>

        <div class="actions">
          <button type="submit" class="submit-btn">Submit</button>
        </div>
      </form>
    </section>
  </main>

  <script>
    import confetti from "@hiseb/confetti";
    import { ApiService } from "@/services/helper";
    import type { QuestionCreate, SurveyCreate } from "@/types/bakend-types";

    const setupRadioOther = (triggerSelector: string, targetSelector: string, groupName: string) => {
      const trigger = document.querySelector(triggerSelector);
      const target = document.querySelector(targetSelector);

      if (!(trigger instanceof HTMLInputElement) || !(target instanceof HTMLInputElement)) return;

      const updateState = () => {
        const isChecked = trigger.checked;
        target.disabled = !isChecked;
        target.required = isChecked;

        isChecked ? target.focus() : (target.value = "");
      };

      document.querySelectorAll(`input[name="${groupName}"]`).forEach((item) => {
        if (item instanceof HTMLInputElement) item.addEventListener("change", updateState);
      });

      updateState();
    };

    const setupCheckboxOther = (triggerSelector: string, targetSelector: string) => {
      const trigger = document.querySelector(triggerSelector);
      const target = document.querySelector(targetSelector);

      if (!(trigger instanceof HTMLInputElement) || !(target instanceof HTMLInputElement)) return;

      const updateState = () => {
        const isChecked = trigger.checked;
        target.disabled = !isChecked;
        target.required = isChecked;
        isChecked ? target.focus() : (target.value = "");
      };

      trigger.addEventListener("change", updateState);
      updateState();
    };

    setupRadioOther('[data-other-toggle="level"]', "#spanish-level-other", "spanish-level");
    setupCheckboxOther('[data-other-toggle="languages"]', "#languages-other");
    setupRadioOther('[data-other-toggle="focus"]', "#focus-other", "focus");

    const helper = new ApiService();
    const submitButton = document.querySelector(".submit-btn");
    const form = document.querySelector(".survey-form");
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!(e.currentTarget instanceof HTMLFormElement)) return;

      submitButton?.setAttribute("disabled", "true");
      submitButton?.classList.add("cursor-not-allowed", "opacity-70");
      submitButton?.classList.remove("hover:brightness-105", "hover:translate-y-[-1px]");

      const formData = new FormData(e.currentTarget);
      const readString = (key: string) => String(formData.get(key) ?? "").trim();

      const spanishLevelBase = readString("spanish-level");
      const spanishLevel = spanishLevelBase === "other" ? readString("spanish-level-other") : spanishLevelBase;

      const focusBase = readString("focus");
      const focus = focusBase === "other" ? readString("focus-other") : focusBase;

      const selectedLanguages = formData
        .getAll("other-languages")
        .map((item) => String(item))
        .filter((item) => item !== "other");
      const languageOther = readString("languages-other");
      const languages = languageOther ? [...selectedLanguages, languageOther] : selectedLanguages;

      const spanishLevelOptions = ["beginner", "A1", "A2", "B1", "B2", "C1", "Other"];
      const otherLanguagesOptions = ["English", "Italian", "French", "Portuguese", "German", "Other"];
      const focusOptions = ["listening", "grammar", "speaking", "Other"];

      const createQuestion = (
        answer: string,
        id: string,
        label: string,
        type: QuestionCreate["type"],
        options?: string[],
        required: boolean = true,
      ): QuestionCreate => ({
        answer,
        id,
        label,
        type,
        required,
        options,
      });

      const newSurvey: SurveyCreate = {
        id: "",
        title: "Group Class Survey",
        description: "Student placement answers",
        userEmail: document.querySelector(".change-account")?.textContent?.trim() || "Anonymous",
        questions: [
          createQuestion(readString("name"), "name", "What is your name?", "text", undefined, true),
          createQuestion(readString("age"), "age", "How old are you?", "number", undefined, true),
          createQuestion(
            readString("native-language"),
            "native-language",
            "What is your native language?",
            "text",
            undefined,
            true,
          ),
          createQuestion(
            spanishLevel,
            "spanish-level",
            "What is your current Spanish level?",
            "radio",
            spanishLevelOptions,
            true,
          ),
          createQuestion(
            languages.join(", "),
            "other-languages",
            "Do you speak any other languages beside your native language?",
            "checkbox",
            otherLanguagesOptions,
            false,
          ),
          createQuestion(
            focus,
            "focus",
            "What would you like to focus on the most during the class?",
            "radio",
            focusOptions,
            true,
          ),
          createQuestion(
            readString("extra-notes"),
            "extra-notes",
            "Is there anything else you would like to add?",
            "textarea",
            undefined,
            false,
          ),
        ],
      };

      console.log("Submitting survey with data:", newSurvey);
      const response = await helper.createSurvey(newSurvey);

      if (response.success) {
        confetti({});
        const params = new URLSearchParams(window.location.search);
        const slugType = params.get("type");
        const weeks = params.get("weeks");
        setTimeout(() => {
          window.location.href = `/payment?type=${slugType}&weeks=${weeks}`;
        }, 3000);
      } else {
        submitButton?.removeAttribute("disabled");
        submitButton?.classList.remove("cursor-not-allowed", "opacity-70");
      }
    });
  </script>

  <style>
    /* Light Mode */
    .light,
    :root:not(.dark) {
      --bg-1: var(--color-background, #fff4e1);
      --bg-2: var(--color-smooth-brown, #fee8d6);
      --ink: var(--color-black, #131313);
      --muted: var(--color-brown, #8a4141);
      --surface: var(--color-white, #fff4e1);
      --line: var(--color-light-brown, #d89c8d);
      --accent: var(--color-red, #6d0006);
      --accent-2: var(--color-salmon, #fa8072);
      --focus: var(--color-light-red, #b2443a);
      --shadow-color: #000;
    }

    /* Dark Mode */
    .dark {
      --bg-1: var(--color-smooth-brown, #3a2b2b);
      --bg-2: var(--color-brown, #5f4949);
      --ink: var(--color-black, #f3f3f3);
      --muted: var(--color-custom-gray, #4b5563);
      --surface: var(--color-white, #131313);
      --line: var(--color-light-brown, #6b5555);
      --accent: var(--color-red, #eb5e61);
      --accent-2: var(--color-salmon, #ff8c7a);
      --focus: var(--color-light-red, #fe9090);
      --shadow-color: #000;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: "Inter", system-ui, sans-serif;
      color: var(--ink);
      transition:
        background 0.3s ease,
        color 0.3s ease;
    }

    :global(.light) body,
    :global(:root:not(.dark)) body {
      background:
        radial-gradient(
          circle at 10% 10%,
          color-mix(in srgb, var(--color-light-salmon, #ffbba8) 45%, transparent) 0,
          transparent 35%
        ),
        radial-gradient(
          circle at 90% 0%,
          color-mix(in srgb, var(--color-light-brown, #d89c8d) 40%, transparent) 0,
          transparent 30%
        ),
        linear-gradient(135deg, var(--bg-1), var(--bg-2));
    }

    :global(.dark) body {
      background: var(--color-smooth-brown, #3a2b2b);
    }

    body {
      min-height: 100vh;
      padding: 2rem 1rem;
    }

    .survey-shell {
      margin: 0 auto;
      max-width: 820px;
      animation: rise-in 0.55s ease-out;
    }

    .survey-card {
      border-radius: 24px;
      border: 1px solid var(--line);
      box-shadow: 0 20px 40px color-mix(in srgb, var(--shadow-color) 12%, transparent);
      overflow: hidden;
      transition:
        background 0.3s ease,
        border-color 0.3s ease,
        box-shadow 0.3s ease;
    }

    :global(.light) .survey-card,
    :global(:root:not(.dark)) .survey-card {
      background: var(--surface);
    }

    :global(.dark) .survey-card {
      background: var(--color-brown, #5f4949);
    }

    .survey-header {
      padding: 2rem;
      border-bottom: 1px solid var(--line);
      transition:
        background 0.3s ease,
        border-color 0.3s ease;
    }

    :global(.light) .survey-header,
    :global(:root:not(.dark)) .survey-header {
      background: linear-gradient(
        140deg,
        color-mix(in srgb, var(--color-white, #fff4e1) 80%, var(--color-light-salmon, #ffbba8) 20%) 0%,
        color-mix(in srgb, var(--color-background, #fff4e1) 70%, var(--color-smooth-brown, #fee8d6) 30%) 100%
      );
    }

    :global(.dark) .survey-header {
      background: linear-gradient(140deg, var(--color-brown, #5f4949) 0%, var(--color-smooth-brown, #3a2b2b) 100%);
    }

    .eyebrow {
      margin: 0;
      font-size: 0.8rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 800;
    }

    h1 {
      margin: 0.45rem 0 0.8rem;
      font-family: "Fraunces", serif;
      font-size: clamp(1.7rem, 2.4vw, 2.35rem);
      line-height: 1.2;
      transition: color 0.3s ease;
    }

    :global(.light) h1,
    :global(:root:not(.dark)) h1 {
      color: inherit;
    }

    :global(.dark) h1 {
      color: #ffffff;
    }

    .description {
      margin: 0;
      max-width: 64ch;
      line-height: 1.55;
      transition: color 0.3s ease;
    }

    :global(.light) .description,
    :global(:root:not(.dark)) .description {
      color: var(--muted);
    }

    :global(.dark) .description {
      color: #e0e0e0;
    }

    .account-row {
      display: flex;
      align-items: center;
      gap: 0.9rem;
      margin-top: 1rem;
      flex-wrap: wrap;
    }

    .email {
      font-weight: 700;
      font-size: 0.95rem;
    }

    .change-account {
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 0.45rem 0.9rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    :global(.light) .change-account,
    :global(:root:not(.dark)) .change-account {
      background: color-mix(in srgb, var(--color-light-salmon, #ffbba8) 25%, var(--surface) 75%);
      color: var(--accent);
    }

    :global(.dark) .change-account {
      background: linear-gradient(120deg, var(--color-red, #eb5e61) 0%, var(--color-light-red, #fe9090) 100%);
      color: var(--color-black, #f3f3f3);
      border-color: var(--color-red, #eb5e61);
    }

    .change-account:hover {
      filter: brightness(1.1);
    }

    .privacy {
      margin: 0.7rem 0 0;
      font-size: 0.9rem;
      color: var(--muted);
    }

    .survey-form {
      display: grid;
      gap: 1rem;
      padding: 1.2rem;
    }

    .question-block {
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.7rem;
      margin: 0;
      min-width: 0;
      min-inline-size: 0;
      overflow: hidden;
      min-width: 0;
      transition:
        background 0.3s ease,
        border-color 0.3s ease;
      overflow: hidden;
    }

    :global(.light) .question-block,
    :global(:root:not(.dark)) .question-block {
      background: color-mix(in srgb, var(--surface) 88%, transparent);
    }

    :global(.dark) .question-block {
      background: color-mix(in srgb, var(--color-smooth-brown, #3a2b2b) 40%, var(--color-brown, #5f4949) 60%);
    }

    .question-title {
      font-weight: 700;
      font-size: 1rem;
      line-height: 1.4;
      padding: 0.6rem 1rem;
      margin: -1rem -1rem 0.5rem -1rem;
      border-radius: 12px 12px 0 0;
      transition:
        background 0.3s ease,
        color 0.3s ease;
    }

    :global(.light) .question-title,
    :global(:root:not(.dark)) .question-title {
      background: color-mix(in srgb, var(--accent-2) 15%, transparent);
      color: var(--accent);
    }

    :global(.dark) .question-title {
      background: linear-gradient(120deg, var(--color-red, #eb5e61) 0%, var(--color-light-red, #fe9090) 100%);
      color: var(--color-black, #f3f3f3);
    }

    input[type="text"],
    input[type="number"],
    textarea {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 11px;
      padding: 0.7rem 0.8rem;
      font-family: inherit;
      font-size: 0.95rem;
      color: var(--ink);
      transition:
        border-color 0.2s ease,
        background 0.3s ease,
        color 0.3s ease;
    }

    :global(.light) input[type="text"],
    :global(.light) input[type="number"],
    :global(.light) textarea,
    :global(:root:not(.dark)) input[type="text"],
    :global(:root:not(.dark)) input[type="number"],
    :global(:root:not(.dark)) textarea {
      background: color-mix(in srgb, var(--surface) 92%, var(--bg-2) 8%);
    }

    :global(.dark) input[type="text"],
    :global(.dark) input[type="number"],
    :global(.dark) textarea {
      background: color-mix(in srgb, var(--color-smooth-brown, #3a2b2b) 60%, var(--color-brown, #5f4949) 40%);
      color: var(--color-black, #f3f3f3);
    }

    input[type="text"]:focus,
    input[type="number"]:focus,
    textarea:focus {
      outline: 2px solid color-mix(in srgb, var(--focus) 18%, transparent);
      border-color: var(--focus);
    }

    input[type="radio"],
    input[type="checkbox"] {
      width: 1rem;
      height: 1rem;
      accent-color: var(--accent-2);
      margin-top: 0.2rem;
    }

    .option-row {
      display: grid;
      grid-template-columns: 20px 1fr;
      align-items: start;
      gap: 0.8rem;
      line-height: 1.45;
      word-break: break-word;
      transition: color 0.3s ease;
      width: 100%;
    }

    :global(.light) .option-row,
    :global(:root:not(.dark)) .option-row {
      color: var(--ink);
    }

    :global(.dark) .option-row {
      color: #f3f3f3;
    }

    .other-input {
      width: 100%;
      max-width: 100%;
    }

    .other-input:disabled {
      opacity: 0.55;
    }

    .actions {
      padding: 0.4rem 0.2rem 0.7rem;
    }

    .submit-btn {
      border: 0;
      border-radius: 12px;
      padding: 0.8rem 1.35rem;
      font-weight: 800;
      font-family: inherit;
      cursor: pointer;
      box-shadow: 0 7px 16px color-mix(in srgb, var(--shadow-color) 20%, transparent);
      transition: all 0.3s ease;
    }

    :global(.light) .submit-btn,
    :global(:root:not(.dark)) .submit-btn {
      background: linear-gradient(
        120deg,
        var(--color-red, #6d0006),
        color-mix(in srgb, var(--color-salmon, #fa8072) 75%, var(--color-red, #6d0006) 25%)
      );
      color: var(--color-white, #fff4e1);
    }

    :global(.dark) .submit-btn {
      background: linear-gradient(120deg, var(--color-red, #eb5e61), var(--color-salmon, #ff8c7a));
      color: var(--color-black, #f3f3f3);
    }

    .submit-btn:hover {
      filter: brightness(1.05);
      transform: translateY(-1px);
    }

    @media (max-width: 640px) {
      body {
        padding: 1rem 0.75rem;
      }

      .survey-header {
        padding: 1.4rem;
      }

      .survey-form {
        padding: 0.8rem;
      }

      .question-block {
        padding: 0.85rem;
      }

      .other-input {
        margin-left: 0;
        width: 100%;
      }

      .option-row {
        grid-template-columns: 24px 1fr;
      }
    }

    @keyframes rise-in {
      from {
        opacity: 0;
        transform: translateY(12px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    input[type="text"],
    input[type="number"],
    textarea {
      width: 100%;
      max-width: 100%;
      display: block;
      box-sizing: border-box;
    }
  </style>
</Layout>
