---
import type { Survey, QuestionType } from "@/types/bakend-types";
import { icons, iconColors } from "@/utils/panel";
import type { IconType } from "@/utils/panel";

interface Props {
  survey: Survey;
  iconType?: IconType;
}

const { survey, iconType = "conversion" } = Astro.props as Props;

const questionTypeLabel: Record<QuestionType, string> = {
  text: "Texto",
  number: "Número",
  radio: "Selección única",
  checkbox: "Selección múltiple",
  textarea: "Texto largo",
};

const questionTypeStyle: Record<QuestionType, string> = {
  text: "bg-[#f2e2d8] text-[#8a4141]",
  number: "bg-[#f2e2d8] text-[#8a4141]",
  radio: "bg-[#ffe0b3] text-[#8a4141]",
  checkbox: "bg-[#ffe0b3] text-[#8a4141]",
  textarea: "bg-[#f7dcd6] text-[#6d0006]",
};

const SUBMITTED_AT_QUESTION_ID = "__submitted_at";

const displayQuestions = survey.questions.filter((question) => question.id !== SUBMITTED_AT_QUESTION_ID);

const resolveAnswer = (question: Survey["questions"][number]): string => {
  const candidate = question.placeholder?.trim();
  return candidate && candidate.length > 0 ? candidate : "Sin respuesta";
};

const selectedAnswerTokens = (question: Survey["questions"][number]): string[] => {
  const answer = resolveAnswer(question);
  if (answer === "Sin respuesta") return [];

  return answer
    .split(",")
    .map((value) => value.trim().toLowerCase())
    .filter(Boolean);
};

const selectedAnswerRawTokens = (question: Survey["questions"][number]): string[] => {
  const answer = resolveAnswer(question);
  if (answer === "Sin respuesta") return [];

  return answer
    .split(",")
    .map((value) => value.trim())
    .filter(Boolean);
};

const isSelectionQuestion = (question: Survey["questions"][number]): boolean => {
  return question.type === "radio" || question.type === "checkbox";
};

const isOtherOption = (option: string): boolean => option.trim().toLowerCase() === "other";

const questionOptionsCatalog: Partial<Record<string, string[]>> = {
  "spanish-level": ["beginner", "A1", "A2", "B1", "B2", "C1", "Other"],
  "other-languages": ["English", "Italian", "French", "Portuguese", "German", "Other"],
  focus: ["listening", "grammar", "speaking", "Other"],
};

const resolveQuestionOptions = (question: Survey["questions"][number]): string[] => {
  if (question.options && question.options.length > 1) {
    return question.options;
  }

  const fallbackOptions = questionOptionsCatalog[question.id];
  if (fallbackOptions && fallbackOptions.length > 0) {
    return fallbackOptions;
  }

  return question.options ?? [];
};

const customOtherValues = (question: Survey["questions"][number]): string[] => {
  const knownOptions = new Set(resolveQuestionOptions(question).map((option) => option.trim().toLowerCase()));
  return selectedAnswerRawTokens(question).filter((token) => !knownOptions.has(token.toLowerCase()));
};

const isOtherSelected = (question: Survey["questions"][number]): boolean => {
  if (!isSelectionQuestion(question)) return false;
  if (customOtherValues(question).length > 0) return true;
  return selectedAnswerTokens(question).includes("other");
};

const resolveDisplayedOptions = (question: Survey["questions"][number]): string[] => {
  return resolveQuestionOptions(question);
};

const resolveInlineAnswer = (question: Survey["questions"][number]): string => {
  if (!isSelectionQuestion(question)) {
    return resolveAnswer(question);
  }

  const customValues = customOtherValues(question);
  if (customValues.length > 0) {
    return customValues.join(", ");
  }

  return resolveAnswer(question);
};

const shouldShowInlineAnswer = (question: Survey["questions"][number]): boolean => {
  if (!isSelectionQuestion(question)) {
    return true;
  }

  return isOtherSelected(question);
};

const isSelectedOption = (question: Survey["questions"][number], option: string): boolean => {
  if (isOtherOption(option)) {
    return isOtherSelected(question);
  }

  return selectedAnswerTokens(question).includes(option.trim().toLowerCase());
};

const surveyOwnerEmail = survey.userEmail?.trim() || "anonymous@amanahacademia.com";
const submittedAtRaw =
  survey.submittedAt ?? survey.questions.find((question) => question.id === SUBMITTED_AT_QUESTION_ID)?.placeholder;

const submittedAtText = (() => {
  if (!submittedAtRaw) return "Fecha no disponible";
  const date = new Date(submittedAtRaw);
  if (Number.isNaN(date.getTime())) return "Fecha no disponible";
  return new Intl.DateTimeFormat("es-ES", {
    dateStyle: "medium",
    timeStyle: "short",
  }).format(date);
})();
---

<article
  class="w-full overflow-x-hidden bg-[#fff4e1] rounded-xl shadow-sm hover:shadow-md transition-shadow p-6 border border-[#fee8d6] mb-6"
>
  <header
    class="flex items-start justify-between gap-4 mb-4 cursor-pointer"
    onclick={`const panel = this.nextElementSibling; panel.classList.toggle('max-h-0'); panel.classList.toggle('opacity-0'); panel.classList.toggle('max-h-[2200px]'); panel.classList.toggle('opacity-100'); this.querySelector('[data-chevron]').classList.toggle('rotate-180')`}
  >
    <div class="flex items-center gap-3">
      <div class={`w-12 h-12 rounded-lg flex items-center justify-center ${iconColors[iconType]}`}>
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={icons[iconType]} />
      </div>
      <div>
        <h3 class="text-[#131313] text-xl font-bold break-all">{surveyOwnerEmail}</h3>
        <p class="text-[#8a4141] text-sm">Enviada el {submittedAtText}</p>
      </div>
    </div>

    <div class="flex items-center gap-2">
      <span class="px-3 py-1 rounded-full bg-[#ffbba8]/30 text-[#8a4141] text-xs font-semibold">
        {displayQuestions.length} preguntas contestadas
      </span>
      <svg
        data-chevron
        class="w-5 h-5 text-[#8a4141] transition-transform duration-300"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
      </svg>
    </div>
  </header>

  <div class="max-h-0 overflow-hidden opacity-0 transition-all duration-300 ease-in-out">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-5">
      <div class="rounded-lg border border-[#fee8d6] bg-[#fff8ef] p-3">
        <p class="text-xs text-[#8a4141] font-semibold uppercase tracking-wide">Email usuario</p>
        <p class="text-sm text-[#131313] break-all">{survey.userEmail}</p>
      </div>
      <div class="rounded-lg border border-[#fee8d6] bg-[#fff8ef] p-3">
        <p class="text-xs text-[#8a4141] font-semibold uppercase tracking-wide">Survey ID</p>
        <p class="text-sm text-[#131313] break-all">{survey.id}</p>
      </div>
    </div>

    <div class="space-y-3">
      {
        displayQuestions.length === 0 ? (
          <p class="text-sm text-[#8a4141] italic">Esta encuesta no contiene preguntas.</p>
        ) : (
          displayQuestions.map((question, index) => (
            <section class="rounded-lg border border-[#fee8d6] bg-[#fff8ef] p-4">
              <div class="flex flex-wrap items-center gap-2 mb-2">
                <span class="text-sm font-bold text-[#6d0006]">Pregunta {index + 1}</span>
                <span class={`text-xs px-2 py-1 rounded-full font-semibold ${questionTypeStyle[question.type]}`}>
                  {questionTypeLabel[question.type] ?? question.type}
                </span>
                <span
                  class={`text-xs px-2 py-1 rounded-full font-semibold ${
                    question.required ? "bg-[#ffd5cf] text-[#6d0006]" : "bg-[#ece9e4] text-[#6b6b6b]"
                  }`}
                >
                  {question.required ? "Obligatoria" : "Opcional"}
                </span>
              </div>

              <p class="text-[#131313] font-medium mb-2">{question.label}</p>

              {shouldShowInlineAnswer(question) && (
                <div class="grid grid-cols-1 md:grid-cols-2 gap-2 text-sm">
                  <div class="md:col-span-2">
                    <span class="text-[#8a4141] font-semibold">Respuesta:</span>
                    <span class="text-[#131313] ml-1">{resolveInlineAnswer(question)}</span>
                  </div>
                </div>
              )}

              {resolveDisplayedOptions(question).length > 0 && (
                <div class="mt-3">
                  <p class="text-xs font-semibold text-[#8a4141] uppercase tracking-wide mb-2">Opciones</p>
                  <div class="flex flex-wrap gap-2.5">
                    {resolveDisplayedOptions(question).map((option) => (
                      <span
                        class={`text-xs px-2.5 py-1 rounded-full border transition-colors ${
                          isSelectedOption(question, option)
                            ? "bg-[#ffd5cf] text-[#6d0006] border-[#f2a89e] font-semibold shadow-sm"
                            : "bg-[#fff4e1] text-[#8a4141] border-[#efcfbf]"
                        }`}
                      >
                        {option}
                      </span>
                    ))}
                  </div>
                </div>
              )}
            </section>
          ))
        )
      }
    </div>
  </div>
</article>
