---
import type { Survey, QuestionType } from "@/types/bakend-types";

interface Props {
  survey: Survey;
  iconType?: "users" | "active" | "new" | "conversion";
}

const { survey, iconType = "conversion" } = Astro.props as Props;

const icons = {
  users: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>`,
  active: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>`,
  new: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>`,
  conversion: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>`,
};

const iconColors = {
  users: "bg-[#b2443a]/20 text-[#6d0006]",
  active: "bg-[#fa8072]/20 text-[#6d0006]",
  new: "bg-[#d89c8d]/30 text-[#8a4141]",
  conversion: "bg-[#ffbba8]/30 text-[#8a4141]",
};

const questionTypeLabel: Record<QuestionType, string> = {
  text: "Texto",
  number: "Número",
  radio: "Selección única",
  checkbox: "Selección múltiple",
  textarea: "Texto largo",
};

const questionTypeStyle: Record<QuestionType, string> = {
  text: "bg-[#f2e2d8] text-[#8a4141]",
  number: "bg-[#f2e2d8] text-[#8a4141]",
  radio: "bg-[#ffe0b3] text-[#8a4141]",
  checkbox: "bg-[#ffe0b3] text-[#8a4141]",
  textarea: "bg-[#f7dcd6] text-[#6d0006]",
};
---

<article class="bg-[#fff4e1] rounded-xl shadow-sm hover:shadow-md transition-shadow p-6 border border-[#fee8d6] mb-6">
  <header class="flex items-start justify-between gap-4 mb-4">
    <div class="flex items-center gap-3">
      <div class={`w-12 h-12 rounded-lg flex items-center justify-center ${iconColors[iconType]}`}>
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={icons[iconType]} />
      </div>
      <div>
        <h3 class="text-[#131313] text-xl font-bold">{survey.title}</h3>
        <p class="text-[#8a4141] text-sm">{survey.description}</p>
      </div>
    </div>

    <span class="px-3 py-1 rounded-full bg-[#ffbba8]/30 text-[#8a4141] text-xs font-semibold">
      {survey.questions.length} preguntas
    </span>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-5">
    <div class="rounded-lg border border-[#fee8d6] bg-[#fff8ef] p-3">
      <p class="text-xs text-[#8a4141] font-semibold uppercase tracking-wide">Email usuario</p>
      <p class="text-sm text-[#131313] break-all">{survey.userEmail}</p>
    </div>
    <div class="rounded-lg border border-[#fee8d6] bg-[#fff8ef] p-3">
      <p class="text-xs text-[#8a4141] font-semibold uppercase tracking-wide">Survey ID</p>
      <p class="text-sm text-[#131313] break-all">{survey.id}</p>
    </div>
  </div>

  <div class="space-y-3">
    {
      survey.questions.length === 0 ? (
        <p class="text-sm text-[#8a4141] italic">Esta encuesta no contiene preguntas.</p>
      ) : (
        survey.questions.map((question, index) => (
          <section class="rounded-lg border border-[#fee8d6] bg-[#fff8ef] p-4">
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <span class="text-sm font-bold text-[#6d0006]">Pregunta {index + 1}</span>
              <span class={`text-xs px-2 py-1 rounded-full font-semibold ${questionTypeStyle[question.type]}`}>
                {questionTypeLabel[question.type] ?? question.type}
              </span>
              <span
                class={`text-xs px-2 py-1 rounded-full font-semibold ${
                  question.required ? "bg-[#ffd5cf] text-[#6d0006]" : "bg-[#ece9e4] text-[#6b6b6b]"
                }`}
              >
                {question.required ? "Obligatoria" : "Opcional"}
              </span>
            </div>

            <p class="text-[#131313] font-medium mb-2">{question.label}</p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-2 text-sm">
              <div>
                <span class="text-[#8a4141] font-semibold">ID:</span>
                <span class="text-[#131313] ml-1">{question.id}</span>
              </div>

              {question.placeholder ? (
                <div>
                  <span class="text-[#8a4141] font-semibold">Placeholder:</span>
                  <span class="text-[#131313] ml-1">{question.placeholder}</span>
                </div>
              ) : (
                <div>
                  <span class="text-[#8a4141] font-semibold">Placeholder:</span>
                  <span class="text-[#6b6b6b] ml-1 italic">No definido</span>
                </div>
              )}
            </div>

            {question.options && question.options.length > 0 && (
              <div class="mt-3">
                <p class="text-xs font-semibold text-[#8a4141] uppercase tracking-wide mb-2">Opciones</p>
                <div class="flex flex-wrap gap-2">
                  {question.options.map((option) => (
                    <span class="text-xs px-2 py-1 rounded-md bg-[#f2e2d8] text-[#8a4141] border border-[#e8cbb8]">
                      {option}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </section>
        ))
      )
    }
  </div>
</article>
