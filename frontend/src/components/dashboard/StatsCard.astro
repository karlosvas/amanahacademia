---
import { icons, iconColors } from "@/utils/panel";
import type { IconType } from "@/utils/panel";

interface Props {
  title: string;
  value: string;
  change: string;
  iconType: IconType;
}

const { title, value, change, iconType } = Astro.props;
---

<div class="bg-[#fff4e1] rounded-xl shadow-sm hover:shadow-md transition-shadow p-6 border border-[#fee8d6]">
  <div class="flex items-center justify-between mb-4">
    <div class={`w-12 h-12 rounded-lg flex items-center justify-center ${iconColors[iconType]}`}>
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={icons[iconType]} />
    </div>
    <span class="text-[#6d0006] text-sm font-semibold">{change}</span>
  </div>
  <h3 class="text-[#8a4141] text-sm font-medium mb-1">{title}</h3>
  <p class="text-3xl font-bold text-[#131313]">{value}</p>
</div>
